{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "attribution": {},
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(bun *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(uv *)",
      "Bash(zig *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Grep",
      "Glob",
      "Skill"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./secrets)",
      "Read(./keys)",
      "Read(./certs)",
      "Read(./credentials)",
      "Bash(rm -rf *)",
      "Bash(npm *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "model": "claude-haiku-4-5",
  "language": "english",
  "spinnerTipsEnabled": false,
  "autoMemoryEnabled": true,
  "modelsByTask": {
    "codeGeneration": "claude-haiku-4-5",
    "codeReview": "claude-haiku-4-5",
    "architecture": "claude-haiku-4-5",
    "exploration": "claude-haiku-4-5",
    "debugging": "claude-haiku-4-5"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
